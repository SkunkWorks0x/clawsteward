# ClawSteward — Mainnet Deployment Configuration
# Copy to .env before running in production against Solana mainnet-beta.
#
# IMPORTANT: Review all values before deploying. Do NOT use default RPC for
# production — public RPC has aggressive rate limits and leaks tx intent to MEV.

# ─── Solana RPC ──────────────────────────────────────────────────────────
# Use a private/dedicated RPC to prevent MEV front-running of simulation queries.
# Helius PRO or Triton recommended. Public RPC is NOT suitable for mainnet.
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# Helius API Key (required for mainnet — enables enriched simulation data)
HELIUS_API_KEY=YOUR_HELIUS_API_KEY

# ─── Price Oracle ────────────────────────────────────────────────────────
# Jupiter Price API v6 (free, mainnet-native, no key required)
JUPITER_PRICE_API=https://price.jup.ag/v6

# ─── Database ────────────────────────────────────────────────────────────
# Production database path — use an absolute path outside the repo
# Back this file up regularly; it contains the Steward Log (source of truth)
DATABASE_PATH=/var/lib/clawsteward/clawsteward.db

# ─── Server Ports ────────────────────────────────────────────────────────
MCP_PORT=3001
DASHBOARD_PORT=3000

# ─── Logging ─────────────────────────────────────────────────────────────
# Use "warn" or "error" in production. "info" is acceptable for initial rollout.
# NEVER use "debug" in production — may log transaction payloads.
LOG_LEVEL=warn
