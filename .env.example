# ClawSteward by ClawStack — Environment Variables
# Copy to .env and fill in values

# Solana RPC URL (required)
# Free: https://api.mainnet-beta.solana.com
# Recommended: Helius (free tier: 100K credits/day) https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Helius API Key (optional — enables enriched simulation data)
# Get free key at https://dev.helius.xyz
HELIUS_API_KEY=

# Jupiter Price API (free, no key needed for basic usage)
# Override only if self-hosting
JUPITER_PRICE_API=https://price.jup.ag/v6

# Database path (defaults to ./data/clawsteward.db)
DATABASE_PATH=./data/clawsteward.db

# MCP Server port (default 3001)
MCP_PORT=3001

# Dashboard port (default 3000)
DASHBOARD_PORT=3000

# Log level: debug | info | warn | error
LOG_LEVEL=info
