{
  "name": "clawsteward",
  "version": "0.1.0",
  "description": "Pre-signing policy enforcement gate and behavioral reputation system for DeFAI agents — by ClawStack",
  "author": "Imani @SkunkWorks0x (ClawStack)",
  "license": "MIT",
  "type": "module",
  "bin": {
    "clawsteward": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "serve": "tsx src/index.ts serve",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dashboard": "cd src/dashboard && next dev",
    "dashboard:build": "cd src/dashboard && next build",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@solana/web3.js": "^1.95.0",
    "better-sqlite3": "^11.0.0",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
